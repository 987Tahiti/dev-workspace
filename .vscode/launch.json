{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch .NET Core Console",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/projects/Windows/bin/Debug/net8.0/YourApp.dll",
      "args": [],
      "cwd": "${workspaceFolder}/projects/Windows",
      "stopAtEntry": false
    },
    {
      "name": "Launch Node.js",
      "type": "pwa-node",
      "request": "launch",
      "program": "${workspaceFolder}/projects/Web/server.js",
      "cwd": "${workspaceFolder}/projects/Web"
    }
  ]
}
